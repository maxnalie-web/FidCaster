{
  "name": "@workspace/farcaster-client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail -n SERVER,VITE -c cyan,green \"API_PORT=3001 tsx server/index.ts\" \"vite --config vite.config.ts --host 0.0.0.0\"",
    "server": "tsx server/index.ts",
    "build": "vite build --config vite.config.ts",
    "serve": "vite preview --config vite.config.ts --host 0.0.0.0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "cap:add:ios": "cap add ios",
    "cap:add:android": "cap add android",
    "cap:sync": "npm run build && cap sync",
    "cap:ios": "npm run build && cap sync ios && cap open ios",
    "cap:android": "npm run build && cap sync android && cap open android",
    "start": "NODE_ENV=production tsx server/index.ts",
    "pm2:start": "pm2 start ecosystem.config.cjs --env production",
    "pm2:stop": "pm2 stop fidcaster-server",
    "pm2:restart": "pm2 restart fidcaster-server",
    "pm2:logs": "pm2 logs fidcaster-server"
  },
  "dependencies": {
    "@capacitor/core": "^8.4.1",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/status-bar": "^8.0.2",
    "@capgo/capacitor-inappbrowser": "^8.6.34",
    "@farcaster/auth-kit": "^0.8.2",
    "@farcaster/core": "^0.19.0",
    "@farcaster/hub-nodejs": "^0.16.0",
    "@farcaster/miniapp-core": "^0.6.0",
    "@farcaster/miniapp-host": "^0.3.0",
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@scure/bip32": "^1.6.2",
    "@scure/bip39": "^1.5.4",
    "@walletconnect/ethereum-provider": "^2.23.10",
    "@walletconnect/sign-client": "^2.23.10",
    "@walletconnect/types": "^2.23.10",
    "@walletconnect/utils": "^2.23.10",
    "better-sqlite3": "^12.11.1",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "ox": "^0.14.29",
    "pg": "^8.13.1",
    "qrcode.react": "^4.2.0",
    "tsx": "catalog:",
    "viem": "^2.31.3",
    "vite-plugin-node-polyfills": "^0.28.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@radix-ui/react-dialog": "^1.1.7",
    "@radix-ui/react-label": "^2.1.3",
    "@radix-ui/react-slot": "^1.2.0",
    "@radix-ui/react-tabs": "^1.1.4",
    "@radix-ui/react-toast": "^1.2.7",
    "@radix-ui/react-tooltip": "^1.2.0",
    "@replit/vite-plugin-cartographer": "catalog:",
    "@replit/vite-plugin-dev-banner": "catalog:",
    "@replit/vite-plugin-runtime-error-modal": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@types/better-sqlite3": "^7.6.13",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/pg": "^8.11.10",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
